{
  "compilerOptions": {
    "types": ["node", "jest", "@testing-library/jest-dom"],
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "downlevelIteration": true,
    "incremental": true,
    "paths": {
      "@/service/database/*": ["./src/service/database/*"],
      "@/app/*": ["./src/app/*"],
      "@/service": ["./src/service/index.ts"],
      "@/service/client": ["./src/service/client/index.ts"],
      "@/service/server": ["./src/service/server/index.ts"],
      "@/service/server/*": ["./src/service/server/*"],
      "@/utilities": ["./src/lib/utilities/index.ts"],
      "@/notifications/*": ["./src/lib/notifications/*"],
      "@/providers/*": ["./src/lib/providers/*"],
      "@/data/*": ["./src/data/*"],
      "@/stores/*": ["./src/lib/stores/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
