{
  "name": "budgy",
  "version": "1.0.0",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint && npm run lint:stylelint",
    "lint:stylelint": "stylelint '**/*.css' --cache",
    "jest": "jest",
    "jest:watch": "jest --watch",
    "prettier:check": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "npm run prettier:check && npm run lint && npm run typecheck && npm run jest",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "seed": "tsx scripts/seed.ts",
    "migrate": "tsx scripts/migrate.ts",
    "export": "tsx scripts/export.ts",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "electron:dev": "next build && yarn electron:compile && electron .",
    "electron:pack": "next build && yarn electron:compile && electron-builder --mac",
    "electron:sync-db": "cp budgy.db ~/Library/Application\\ Support/Budgy/budgy.db && echo 'DB synced to Electron userData'"
  },
  "dependencies": {
    "@mantine/charts": "^8.3.3",
    "@mantine/core": "^8.3.3",
    "@mantine/dropzone": "^8.3.3",
    "@mantine/hooks": "^8.3.3",
    "@mantine/notifications": "^8.3.3",
    "@netlify/blobs": "^10.7.8",
    "@next/bundle-analyzer": "^15.5.4",
    "@tabler/icons-react": "^3.35.0",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-virtual": "^3.13.24",
    "better-sqlite3": "^12.10.0",
    "immer": "^10.1.3",
    "next": "16.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.2.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@electron/rebuild": "^4.0.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@netlify/plugin-nextjs": "^5.15.11",
    "@next/eslint-plugin-next": "^15.5.4",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-styling-webpack": "^2.0.0",
    "@storybook/blocks": "^8.6.14",
    "@storybook/nextjs": "^9.1.10",
    "@storybook/react": "^9.1.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.0",
    "@types/wait-on": "^5.3.4",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "babel-loader": "^10.0.0",
    "dotenv": "^17.3.1",
    "electron": "33",
    "electron-builder": "26.8.1",
    "eslint": "^9.36.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-mantine": "^4.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.0",
    "eslint-plugin-testing-library": "^7.11.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.6.2",
    "storybook": "^9.1.10",
    "storybook-dark-mode": "^4.0.2",
    "stylelint": "^16.24.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "ts-jest": "^29.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.10"
  },
  "packageManager": "yarn@4.4.1"
}
